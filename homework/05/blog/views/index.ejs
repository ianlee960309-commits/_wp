<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>Blog</title>
  <style>
    body { font-family: sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; }
    a { color: #06c; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .post { border-bottom: 1px solid #ddd; padding: 1rem 0; }
    .post h2 { margin: 0 0 .25rem; }
    .post time { color: #888; font-size: .875rem; }
  </style>
</head>
<body>
  <h1>Blog</h1>
  <p><a href="/posts/new">New Post</a></p>
  <% posts.forEach(post => { %>
    <div class="post">
      <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
      <time><%= post.created_at %></time>
    </div>
  <% }) %>
  <% if (posts.length === 0) { %>
    <p>No posts yet.</p>
  <% } %>
</body>
</html>
