<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>New Post</title>
  <style>
    body { font-family: sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; }
    a { color: #06c; text-decoration: none; }
    a:hover { text-decoration: underline; }
    label { display: block; margin: 1rem 0 .25rem; font-weight: bold; }
    input, textarea { width: 100%; padding: .5rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
    textarea { min-height: 200px; }
    button { margin-top: 1rem; padding: .5rem 1.5rem; }
  </style>
</head>
<body>
  <p><a href="/posts">&larr; Back</a></p>
  <h1>New Post</h1>
  <form action="/posts" method="POST">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required>
    <label for="content">Content</label>
    <textarea id="content" name="content" required></textarea>
    <button type="submit">Publish</button>
  </form>
</body>
</html>
